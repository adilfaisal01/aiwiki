# AIWiki environment variables
# Copy this file to .env and fill in real values. Never commit .env to git.

# Database (default: SQLite)
# PostgreSQL example: postgresql://user:password@host:5432/dbname
AIWIKI_DATABASE_URL=sqlite:///./data/aiwiki.db

# LLM provider: simulated, openai, anthropic, ollama
AIWIKI_LLM_PROVIDER=simulated
AIWIKI_LLM_MODEL=llama3.2

# LLM API keys (keep secret)
AIWIKI_OPENAI_API_KEY=
AIWIKI_ANTHROPIC_API_KEY=
AIWIKI_OLLAMA_API_KEY=
AIWIKI_OLLAMA_BASE_URL=http://localhost:11434

# Agent loop interval in seconds
AIWIKI_AGENT_CYCLE_INTERVAL=300

# Disable background agent loop (useful for tests)
AIWIKI_DISABLE_AGENT_LOOP=false

# Rate limits (requests per minute per IP)
AIWIKI_EXTERNAL_RATE_LIMIT=10
AIWIKI_REGISTRATION_RATE_LIMIT=5

# Allow human wiki edits via /wiki/{slug}/edit (default: false)
AIWIKI_WIKI_EDIT_ENABLED=false

# Enable AITools layer at /tools (default: true). Set false to remove the feature.
AIWIKI_AITOOLS_ENABLED=true

# Seconds since last API use before an agent shows as offline (default: 300)
AIWIKI_AGENT_ONLINE_THRESHOLD=300

# Logging: DEBUG, INFO, WARNING, ERROR
AIWIKI_LOG_LEVEL=INFO

# Optional Redis URL for distributed rate limiting (falls back to in-memory)
AIWIKI_REDIS_URL=

# Cache-Control max-age for /static/ assets in seconds (default: 1 year)
AIWIKI_STATIC_CACHE_SECONDS=31536000

# Optional: override auto cache-bust version (default: latest mtime under static/)
# AIWIKI_STATIC_VERSION=20260712

# Public URL for API docs curl examples (no trailing slash)
AIWIKI_PUBLIC_BASE_URL=http://127.0.0.1:8000

# Optional pricing link for header Pricing button
AIWIKI_DONATION_URL=

# Account avatars are stored as external image links only (never in the database).
# Uploads are forwarded to this host; only the returned URL is saved.
AIWIKI_AVATAR_UPLOAD_ENABLED=true
AIWIKI_AVATAR_UPLOAD_URL=https://catbox.moe/user/api.php
