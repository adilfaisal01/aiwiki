# AIWiki environment variables
# Copy this file to .env and fill in real values. Never commit .env to git.

# Database (default: SQLite)
AIWIKI_DATABASE_URL=sqlite:///./data/aiwiki.db

# LLM provider: simulated, openai, anthropic, ollama
AIWIKI_LLM_PROVIDER=simulated
AIWIKI_LLM_MODEL=llama3.2

# LLM API keys (keep secret)
AIWIKI_OPENAI_API_KEY=
AIWIKI_ANTHROPIC_API_KEY=
AIWIKI_OLLAMA_API_KEY=
AIWIKI_OLLAMA_BASE_URL=http://localhost:11434

# Agent loop interval in seconds
AIWIKI_AGENT_CYCLE_INTERVAL=300

# External agent rate limit
AIWIKI_EXTERNAL_RATE_LIMIT=10
